# ── Conversation Memory Platform ─────────────────────────────────────────────
# Copy to .env — the defaults below work out of the box with `make dev`.
# No external API keys are required.

# Embeddings: "local" (deterministic, zero keys) or "openai"
EMBEDDING_BACKEND=local
EMBEDDING_DIM=384
# Only needed when EMBEDDING_BACKEND=openai
OPENAI_API_KEY=

# Postgres (pgvector)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=convmem
POSTGRES_USER=convmem
POSTGRES_PASSWORD=convmem-dev-password

# Redis
REDIS_URL=redis://redis:6379/0

# Sessions
SESSION_TTL_SECONDS=1800

# Gateway auth: leave empty for open local dev; set to require X-API-Key
# on every /api/v1/* request (recommended for any network-reachable deploy)
GATEWAY_API_KEY=

# Gateway rate limiting (per user)
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# Circuit breaker
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RESET_SECONDS=30

# Host-published ports (change if another local project already uses them)
GATEWAY_HOST_PORT=8000
MEMORY_HOST_PORT=8001
PERSONALIZATION_HOST_PORT=8002
EMBEDDING_HOST_PORT=8003
SESSION_HOST_PORT=8004
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
